---
---

<div class="sky" aria-hidden="true">
  <div class="sky__sun"></div>
  <div class="sky__mountain sky__mountain--left"></div>
  <div class="sky__mountain sky__mountain--right"></div>
</div>

<style>
  .sky {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .sky__sun {
    position: absolute;
    left: 50%;
    bottom: -14vw;
    width: 46vw;
    height: 46vw;
    max-width: 680px;
    max-height: 680px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--accent-bright) 40%, transparent) 0%,
      color-mix(in srgb, var(--accent) 20%, transparent) 42%,
      transparent 70%
    );
    animation: sun-rise 2.4s var(--ease-out) both;
  }

  .sky__mountain {
    position: absolute;
    bottom: -1px;
    width: 46%;
    height: 24vh;
    background: linear-gradient(
      to top,
      var(--surface-deep),
      color-mix(in srgb, var(--surface-deep) 50%, transparent)
    );
  }

  .sky__mountain--left {
    left: 0;
    clip-path: polygon(0 100%, 0 28%, 55% 62%, 100% 100%);
  }

  .sky__mountain--right {
    right: 0;
    clip-path: polygon(100% 100%, 100% 28%, 45% 62%, 0 100%);
  }

  @media (max-width: 48rem) {
    .sky__mountain {
      height: 16vh;
    }

    .sky__sun {
      width: 78vw;
      height: 78vw;
      bottom: -24vw;
    }
  }
</style>
