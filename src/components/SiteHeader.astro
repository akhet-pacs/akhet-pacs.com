---
import AkhetGlyph from "../assets/akhet-glyph.svg";
import LocaleSwitcher from "./LocaleSwitcher.astro";
import MobileMenu from "./MobileMenu.astro";
import { buildNavigation } from "../data/navigation";
import { site } from "../data/site";
import { localePath, resolveLocale, useDict } from "../i18n";

const locale = resolveLocale(Astro.currentLocale);
const t = useDict(locale);
const navigation = buildNavigation(locale);
---

<header class="header">
  <div class="shell header__inner">
    <a class="header__brand" href={localePath(locale)}>
      <AkhetGlyph class="header__glyph" aria-hidden="true" />
      <span class="header__name">{site.name}</span>
    </a>

    <nav class="header__nav" aria-label={t.footer.navLabel}>
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>

    <LocaleSwitcher current={locale} label={t.menu.language} class="header__locales" />

    <button
      class="header__toggle"
      type="button"
      data-menu-toggle
      aria-expanded="false"
      aria-controls="menu-mobile"
      aria-label={t.menu.open}
      data-label-open={t.menu.open}
      data-label-close={t.menu.close}
    >
      <span class="header__bars" aria-hidden="true"></span>
    </button>
  </div>
</header>

<MobileMenu locale={locale} />

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 30;
    background: color-mix(in srgb, var(--surface) 88%, transparent);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--rule-color);
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    min-height: var(--header-height);
  }

  .header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
  }

  .header__glyph {
    width: 1.25rem;
    height: auto;
    flex-shrink: 0;
    color: var(--accent);
  }

  .header__name {
    font-family: var(--font-display);
    font-weight: 800;
    letter-spacing: -0.03em;
    font-size: 1.05rem;
    white-space: nowrap;
  }

  .header__nav {
    display: flex;
    gap: 1.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .header__nav a {
    text-decoration: none;
    color: var(--ink-soft);
    padding-block: 0.35rem;
    border-bottom: 1px solid transparent;
    transition:
      color var(--duration-fast) var(--ease-out),
      border-color var(--duration-fast) var(--ease-out);
  }

  .header__nav a:hover {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .header__toggle {
    display: none;
    width: 2.75rem;
    height: 2.75rem;
    margin-right: -0.6rem;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .header__bars,
  .header__bars::before,
  .header__bars::after {
    display: block;
    width: 1.35rem;
    height: 2px;
    background: var(--ink);
    transition:
      transform var(--duration-fast) var(--ease-out),
      opacity var(--duration-fast) var(--ease-out);
  }

  .header__bars::before,
  .header__bars::after {
    content: "";
    position: absolute;
  }

  .header__bars::before {
    transform: translateY(-0.4rem);
  }

  .header__bars::after {
    transform: translateY(0.4rem);
  }

  .header__toggle[aria-expanded="true"] .header__bars {
    background: transparent;
  }

  .header__toggle[aria-expanded="true"] .header__bars::before {
    transform: rotate(45deg);
    background: var(--accent-bright);
  }

  .header__toggle[aria-expanded="true"] .header__bars::after {
    transform: rotate(-45deg);
    background: var(--accent-bright);
  }

  @media (max-width: 60rem) {
    .header__nav {
      display: none;
    }

    .header__toggle {
      display: inline-flex;
    }
  }
</style>

