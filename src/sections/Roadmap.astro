---
import { roadmap } from "../data/site";

const statusLabel = {
  "em-desenvolvimento": "Em desenvolvimento",
  planejado: "Planejado",
} as const;
---

<section class="section" id="roadmap">
  <div class="shell">
    <header class="roadmap__header">
      <p class="eyebrow">Roadmap · onde isto vai chegar</p>
      <h2>Do visualizador ao PACS completo</h2>
      <p class="lede">
        Cinco fases, em ordem, documentadas no repositório com estudo de seis concorrentes. Cada
        fase só começa quando a anterior está em uso de verdade.
      </p>
    </header>

    <ol class="roadmap__list">
      {
        roadmap.map((phase) => (
          <li class="phase" data-status={phase.status}>
            <div class="phase__marker">
              <span class="phase__index tabular">{phase.index}</span>
              <span class="phase__status">{statusLabel[phase.status]}</span>
            </div>
            <div class="phase__body">
              <h3>{phase.name}</h3>
              <p class="phase__summary">{phase.summary}</p>
              <ul class="phase__items">
                {phase.items.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>

<style>
  .roadmap__header {
    display: grid;
    gap: 1.25rem;
    justify-items: start;
    max-width: 52rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }

  .roadmap__list {
    display: grid;
  }

  .phase {
    display: grid;
    grid-template-columns: minmax(0, 12rem) minmax(0, 1fr);
    gap: clamp(1rem, 4vw, 3rem);
    padding-block: 2.25rem;
    border-top: 1px solid var(--rule-color);
  }

  .phase:last-child {
    border-bottom: 1px solid var(--rule-color);
  }

  .phase__marker {
    display: grid;
    gap: 0.5rem;
    align-content: start;
  }

  .phase__index {
    font-size: 2rem;
    font-weight: 500;
    line-height: 1;
    color: var(--ink-faint);
  }

  .phase[data-status="em-desenvolvimento"] .phase__index {
    color: var(--accent);
  }

  .phase__status {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  .phase[data-status="em-desenvolvimento"] .phase__status {
    color: var(--accent);
  }

  .phase__body {
    display: grid;
    gap: 1rem;
  }

  .phase__summary {
    color: var(--ink-soft);
    max-width: 52ch;
  }

  .phase__items {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
    gap: 0.5rem 2rem;
    color: var(--ink-soft);
    font-size: 1rem;
  }

  .phase__items li::before {
    content: "—";
    margin-right: 0.6rem;
    color: var(--ink-faint);
  }

  @media (max-width: 48rem) {
    .phase {
      grid-template-columns: minmax(0, 1fr);
      gap: 1rem;
    }

    .phase__marker {
      display: flex;
      align-items: baseline;
      gap: 1rem;
    }
  }
</style>
