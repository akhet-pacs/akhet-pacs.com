---
import { Icon } from "astro-icon/components";
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).status;
---

<section class="section" id="agora">
  <div class="shell status">
    <header class="status__header">
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.titleLines[0]}<br />{t.titleLines[1]}</h2>
    </header>

    <div class="status__body">
      <p class="lede">{t.lede}</p>
      <p class="status__honest">
        <Icon name="lucide:construction" />
        {t.honest}
      </p>
    </div>
  </div>
</section>

<style>
  .status {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .status__header {
    display: grid;
    gap: 1.25rem;
  }

  .status__body {
    display: grid;
    gap: 1.75rem;
  }

  .status__honest {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: 1rem;
    padding: 1.5rem;
    border: 1px solid var(--rule-color);
    border-left: 3px solid var(--accent);
    color: var(--ink-soft);
    background: var(--surface-raised);
  }

  .status__honest svg {
    width: 1.35rem;
    height: 1.35rem;
    color: var(--accent);
    margin-top: 0.2rem;
  }

  @media (max-width: 62rem) {
    .status {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 48rem) {
    .status {
      gap: 1.75rem;
    }

    .status__body {
      gap: 1.25rem;
    }

    .status__honest {
      grid-template-columns: minmax(0, 1fr);
      gap: 0.75rem;
      padding: 1.25rem;
    }

    .status__honest svg {
      margin-top: 0;
    }
  }
</style>
