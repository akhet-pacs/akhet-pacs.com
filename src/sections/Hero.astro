---
import { Icon } from "astro-icon/components";
import HorizonBackdrop from "../components/HorizonBackdrop.astro";
import StatRow from "../components/StatRow.astro";
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).hero;
---

<section class="hero">
  <HorizonBackdrop />

  <div class="shell hero__inner">
    <p class="eyebrow hero__eyebrow">
      <span class="hero__pulse" aria-hidden="true"></span>
      {t.badge}
    </p>
    <h1 class="hero__title">
      <span class="hero__line">{t.lines[0]}</span>
      <span class="hero__line">{t.lines[1]}</span>
      <span class="hero__line hero__line--accent">{t.lines[2]}</span>
    </h1>
    <p class="lede hero__lede">{t.lede}</p>
    <div class="cluster">
      <a class="btn btn--solid" href="#construir">
        {t.ctaPrimary}
        <Icon name="lucide:arrow-down-right" />
      </a>
      <a class="btn btn--ghost" href="#visualizador">{t.ctaSecondary}</a>
    </div>
  </div>

  <div class="shell hero__stats">
    <StatRow stats={t.stats} />
  </div>

  <hr class="rule-horizon" />
</section>

<style>
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .hero__inner {
    position: relative;
    display: grid;
    gap: 2rem;
    justify-items: start;
    padding-top: clamp(4rem, 10vh, 8rem);
  }

  .hero__eyebrow {
    color: var(--ink-soft);
  }

  .hero__pulse {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--accent-bright);
    animation: pulse 2.4s ease-out infinite;
  }

  .hero__title {
    font-size: clamp(2.9rem, 9.5vw, 8rem);
    text-transform: uppercase;
    letter-spacing: -0.045em;
    display: grid;
  }

  .hero__line {
    display: block;
    animation: line-up 0.9s var(--ease-out) both;
  }

  .hero__line:nth-child(2) {
    animation-delay: 0.12s;
  }

  .hero__line:nth-child(3) {
    animation-delay: 0.24s;
  }

  .hero__line--accent {
    color: var(--accent-bright);
  }

  .hero__lede {
    max-width: 52ch;
    animation: line-up 0.9s var(--ease-out) 0.36s both;
  }

  .hero__inner .cluster {
    animation: line-up 0.9s var(--ease-out) 0.48s both;
  }

  .hero__stats {
    position: relative;
    margin-top: clamp(3rem, 7vh, 5.5rem);
  }

  @media (max-width: 48rem) {
    .hero {
      min-height: 0;
      padding-bottom: 0;
    }

    .hero__inner {
      padding-top: clamp(2.5rem, 8vh, 4rem);
      gap: 1.5rem;
    }

    .hero__title {
      font-size: clamp(2.6rem, 11vw, 3.6rem);
    }

    .hero__stats {
      margin-top: 2.5rem;
    }
  }
</style>
