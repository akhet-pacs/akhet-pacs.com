---
import { Icon } from "astro-icon/components";
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).hero;
---

<section class="hero">
  <div class="hero__sky" aria-hidden="true">
    <div class="hero__sun"></div>
    <div class="hero__mountain hero__mountain--left"></div>
    <div class="hero__mountain hero__mountain--right"></div>
  </div>

  <div class="shell hero__inner">
    <p class="eyebrow hero__eyebrow">
      <span class="hero__pulse" aria-hidden="true"></span>
      {t.badge}
    </p>
    <h1 class="hero__title">
      <span class="hero__line">{t.lines[0]}</span>
      <span class="hero__line">{t.lines[1]}</span>
      <span class="hero__line hero__line--accent">{t.lines[2]}</span>
    </h1>
    <p class="lede hero__lede">{t.lede}</p>
    <div class="cluster">
      <a class="btn btn--solid" href="#construir">
        {t.ctaPrimary}
        <Icon name="lucide:arrow-down-right" />
      </a>
      <a class="btn btn--ghost" href="#visualizador">{t.ctaSecondary}</a>
    </div>
  </div>

  <div class="shell hero__stats" role="list">
    {
      t.stats.map((stat) => (
        <div class="hero__stat" role="listitem">
          <span class="hero__stat-value tabular">{stat.value}</span>
          <span class="hero__stat-label">{stat.label}</span>
        </div>
      ))
    }
  </div>

  <hr class="rule-horizon" />
</section>
<style>
  .hero {
    position: relative;
    min-height: calc(100svh - var(--header-height));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    overflow: hidden;
  }

  .hero__sky {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .hero__sun {
    position: absolute;
    left: 50%;
    bottom: -14vw;
    width: 46vw;
    height: 46vw;
    max-width: 680px;
    max-height: 680px;
    transform: translateX(-50%);
    border-radius: 50%;
    background: radial-gradient(
      circle,
      color-mix(in srgb, var(--accent-bright) 40%, transparent) 0%,
      color-mix(in srgb, var(--accent) 20%, transparent) 42%,
      transparent 70%
    );
    animation: sun-rise 2.4s var(--ease-out) both;
  }

  .hero__mountain {
    position: absolute;
    bottom: -1px;
    width: 46%;
    height: 24vh;
    background: linear-gradient(
      to top,
      var(--surface-deep),
      color-mix(in srgb, var(--surface-deep) 50%, transparent)
    );
  }

  .hero__mountain--left {
    left: 0;
    clip-path: polygon(0 100%, 0 28%, 55% 62%, 100% 100%);
  }

  .hero__mountain--right {
    right: 0;
    clip-path: polygon(100% 100%, 100% 28%, 45% 62%, 0 100%);
  }

  .hero__inner {
    position: relative;
    display: grid;
    gap: 2rem;
    justify-items: start;
    padding-top: clamp(4rem, 10vh, 8rem);
  }

  .hero__eyebrow {
    color: var(--ink-soft);
  }

  .hero__pulse {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: var(--accent-bright);
    animation: pulse 2.4s ease-out infinite;
  }

  .hero__title {
    font-size: clamp(2.9rem, 9.5vw, 8rem);
    text-transform: uppercase;
    letter-spacing: -0.045em;
    display: grid;
  }

  .hero__line {
    display: block;
    animation: line-up 0.9s var(--ease-out) both;
  }

  .hero__line:nth-child(2) {
    animation-delay: 0.12s;
  }

  .hero__line:nth-child(3) {
    animation-delay: 0.24s;
  }

  .hero__line--accent {
    color: var(--accent-bright);
  }

  .hero__lede {
    max-width: 52ch;
    animation: line-up 0.9s var(--ease-out) 0.36s both;
  }

  .hero__inner .cluster {
    animation: line-up 0.9s var(--ease-out) 0.48s both;
  }

  .hero__stats {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: clamp(3rem, 7vh, 5.5rem);
    border-top: 1px solid var(--rule-color);
  }

  .hero__stat {
    display: grid;
    gap: 0.35rem;
    padding: 1.5rem 1.5rem 2rem 0;
    border-right: 1px solid var(--rule-color);
  }

  .hero__stat + .hero__stat {
    padding-left: 1.5rem;
  }

  .hero__stat:last-child {
    border-right: 0;
  }

  .hero__stat-value {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .hero__stat-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-faint);
  }

  @keyframes sun-rise {
    from {
      transform: translateX(-50%) translateY(16%);
      opacity: 0;
    }
    to {
      transform: translateX(-50%) translateY(0);
      opacity: 1;
    }
  }

  @keyframes line-up {
    from {
      transform: translateY(0.6em);
      opacity: 0;
    }
    to {
      transform: translateY(0);
      opacity: 1;
    }
  }

  @keyframes pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent-bright) 55%, transparent);
    }
    70% {
      box-shadow: 0 0 0 0.65rem transparent;
    }
    100% {
      box-shadow: 0 0 0 0 transparent;
    }
  }

  @media (max-width: 48rem) {
    .hero__stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .hero__stat,
    .hero__stat + .hero__stat {
      padding-inline: 0;
      border-right: 0;
    }
  }
</style>
