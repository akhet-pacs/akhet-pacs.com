---
import { Icon } from "astro-icon/components";
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).capabilities;
---

<section class="section">
  <div class="shell">
    <header class="section-header section-header--spaced">
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.titleLines[0]}<br />{t.titleLines[1]}</h2>
      <p class="lede">{t.lede}</p>
    </header>

    <ul class="capabilities__grid">
      {
        t.items.map((capability) => (
          <li class="capability">
            <Icon class="capability__icon" name={capability.icon} />
            <h3>{capability.title}</h3>
            <p>{capability.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .capabilities__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    border-top: 1px solid var(--rule-color);
  }

  .capability {
    display: grid;
    gap: 0.75rem;
    align-content: start;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border-bottom: 1px solid var(--rule-color);
    border-right: 1px solid var(--rule-color);
  }

  .capability:nth-child(3n) {
    border-right: 0;
  }

  .capability__icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent);
    stroke-width: 1.5;
    margin-bottom: 0.5rem;
  }

  .capability p {
    color: var(--ink-soft);
    font-size: 1rem;
  }

  @media (max-width: 62rem) {
    .capabilities__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .capability:nth-child(3n) {
      border-right: 1px solid var(--rule-color);
    }

    .capability:nth-child(2n) {
      border-right: 0;
    }
  }

  @media (max-width: 42rem) {
    .capabilities__grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .capability {
      border-right: 0;
    }

    .capability:nth-child(3n) {
      border-right: 0;
    }
  }

  @media (max-width: 42rem) {

    .capability {
      padding: 1.35rem 0;
    }
  }
</style>
