---
import { Icon } from "astro-icon/components";
import { site } from "../data/site";
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).contribute;
---

<section class="section section-raised" id="construir">
  <div class="shell contribute">
    <header class="contribute__header">
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.title}</h2>
      <p class="lede">{t.lede}</p>
    </header>

    <ul class="contribute__grid">
      {
        t.areas.map((area) => (
          <li class="contribute__card">
            <Icon class="contribute__icon" name={area.icon} />
            <h3>{area.title}</h3>
            <p>{area.body}</p>
          </li>
        ))
      }
    </ul>

    <div class="contribute__cta">
      <p>{t.ctaText}</p>
      <div class="cluster">
        <a
          class="btn btn--solid"
          href={`${site.whatsapp}?text=${encodeURIComponent(t.whatsappMessage)}`}
          rel="noreferrer noopener"
          target="_blank"
        >
          <Icon name="simple-icons:whatsapp" />
          {t.btnWhatsapp}
        </a>
        <a class="btn btn--ghost" href={`mailto:${site.contact}`}>
          <Icon name="lucide:mail" />
          {t.btnEmail}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contribute {
    display: grid;
    gap: clamp(2.5rem, 5vw, 4rem);
  }

  .contribute__header {
    display: grid;
    gap: 1.25rem;
    justify-items: start;
    max-width: 56rem;
  }

  .contribute__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.25rem;
  }

  .contribute__card {
    display: grid;
    gap: 0.75rem;
    align-content: start;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    border: 1px solid var(--rule-color);
    background: var(--surface);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .contribute__card:hover {
    border-color: var(--accent);
  }

  .contribute__icon {
    width: 1.5rem;
    height: 1.5rem;
    color: var(--accent);
    margin-bottom: 0.35rem;
  }

  .contribute__card p {
    color: var(--ink-soft);
    font-size: 1rem;
  }

  .contribute__cta {
    display: grid;
    gap: 1.5rem;
    justify-items: start;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule-color);
  }

  .contribute__cta > p {
    max-width: 56ch;
    color: var(--ink-soft);
  }

  @media (max-width: 52rem) {
    .contribute__grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }

  @media (max-width: 52rem) {
    .contribute {
      gap: 2rem;
    }

    .contribute__card {
      padding: 1.35rem;
    }

    .contribute__cta {
      gap: 1.25rem;
    }
  }
</style>
