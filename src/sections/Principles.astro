---
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).principles;
---

<section class="section" id="principios">
  <div class="shell principles">
    <header class="principles__header">
      <p class="eyebrow">{t.eyebrow}</p>
      <h2>{t.titleLines[0]}<br />{t.titleLines[1]}</h2>
      <p class="lede">{t.lede}</p>
    </header>

    <dl class="principles__list">
      {
        t.items.map((principle) => (
          <div class="principle">
            <dt>{principle.title}</dt>
            <dd>{principle.body}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>

<style>
  .principles {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }

  .principles__header {
    display: grid;
    gap: 1.25rem;
    justify-items: start;
    position: sticky;
    top: 6rem;
  }

  .principles__list {
    display: grid;
    margin: 0;
  }

  .principle {
    display: grid;
    gap: 0.5rem;
    padding-block: 1.75rem;
    border-top: 1px solid var(--rule-color);
  }

  .principle:last-child {
    border-bottom: 1px solid var(--rule-color);
  }

  .principle dt {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.25rem;
    letter-spacing: -0.02em;
  }

  .principle dd {
    margin: 0;
    color: var(--ink-soft);
  }

  @media (max-width: 62rem) {
    .principles {
      grid-template-columns: minmax(0, 1fr);
    }

    .principles__header {
      position: static;
    }
  }
</style>
