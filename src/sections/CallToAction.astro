---
import { Icon } from "astro-icon/components";
import { site } from "../data/site";
import { useDict } from "../i18n";

const t = useDict(Astro.currentLocale).clinics;
---

<section class="section-tight cta">
  <div class="shell-narrow cta__inner">
    <p class="eyebrow">{t.eyebrow}</p>
    <h2>{t.title}</h2>
    <p class="lede">{t.lede}</p>
    <div class="cluster">
      <a
        class="btn btn--solid"
        href={`${site.whatsapp}?text=${encodeURIComponent(t.whatsappMessage)}`}
        rel="noreferrer noopener"
        target="_blank"
      >
        <Icon name="simple-icons:whatsapp" />
        {t.btnWhatsapp}
      </a>
      <a class="btn btn--ghost" href={`mailto:${site.contact}`}>
        <Icon name="lucide:mail" />
        {site.contact}
      </a>
    </div>
  </div>
</section>

<style>
  .cta {
    background: var(--surface);
    border-top: 1px solid var(--rule-color);
  }

  .cta__inner {
    display: grid;
    gap: 1.5rem;
    justify-items: start;
  }
</style>
