---
import "../styles/global.css";
import { localePath, locales, resolveLocale } from "../i18n";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const locale = resolveLocale(Astro.currentLocale);
const langTags = { pt: "pt-BR", en: "en", es: "es" } as const;
const ogLocales = { pt: "pt_BR", en: "en_US", es: "es_ES" } as const;
const siteUrl = Astro.site ?? new URL("https://akhetpacs.com");
const canonical = new URL(localePath(locale), siteUrl);
const ogImage = new URL("/og.png", siteUrl);

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": `${siteUrl.origin}/#organization`,
      name: "Akhet PACS",
      url: siteUrl.origin,
      logo: new URL("/favicon.svg", siteUrl).href,
    },
    {
      "@type": "SoftwareApplication",
      name: "Akhet PACS",
      applicationCategory: "MedicalApplication",
      operatingSystem: "Windows, macOS, Linux",
      description,
      url: canonical.href,
      image: ogImage.href,
      publisher: { "@id": `${siteUrl.origin}/#organization` },
      offers: {
        "@type": "Offer",
        price: "0",
        priceCurrency: "BRL",
      },
    },
  ],
};
---

<!doctype html>
<html lang={langTags[locale]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline define:vars={{ current: locale, defaultLocale: "pt" }}>
      // Redireciona o visitante para o idioma dele apenas a partir da raiz "/"
      // (nunca de /en/ ou /es/, que já são escolhas explícitas de URL).
      // A escolha manual no seletor tem prioridade e é guardada em localStorage.
      (function () {
        var KEY = "akhet-locale";
        var PATHS = { pt: "/", en: "/en/", es: "/es/" };
        if (current !== defaultLocale) return;

        var stored = null;
        try {
          stored = localStorage.getItem(KEY);
        } catch (e) {}

        var target = stored;
        if (!target) {
          var langs = navigator.languages || [navigator.language || "pt"];
          for (var i = 0; i < langs.length && !target; i++) {
            var l = (langs[i] || "").toLowerCase();
            if (l.indexOf("es") === 0) target = "es";
            else if (l.indexOf("en") === 0) target = "en";
            else if (l.indexOf("pt") === 0) target = "pt";
          }
        }

        if (target && target !== current && PATHS[target]) {
          location.replace(PATHS[target] + location.search + location.hash);
        }
      })();

      // Grava a escolha manual de idioma feita no seletor.
      document.addEventListener("click", function (e) {
        var el = e.target;
        var link = el && el.closest ? el.closest("[data-locale]") : null;
        if (!link) return;
        try {
          localStorage.setItem("akhet-locale", link.getAttribute("data-locale"));
        } catch (err) {}
      });
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <meta property="og:site_name" content="Akhet PACS" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />
    <meta property="og:locale" content={ogLocales[locale]} />
    {
      locales
        .filter((code) => code !== locale)
        .map((code) => <meta property="og:locale:alternate" content={ogLocales[code]} />)
    }

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#05090f" />
    <link rel="canonical" href={canonical} />
    {
      locales.map((code) => (
        <link rel="alternate" hreflang={langTags[code]} href={new URL(localePath(code), siteUrl)} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={siteUrl} />
    <script
      type="application/ld+json"
      is:inline
      set:html={JSON.stringify(structuredData)}
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;700;800&family=IBM+Plex+Mono:wght@400;500&family=Source+Serif+4:opsz,wght@8..60,400;8..60,600&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
